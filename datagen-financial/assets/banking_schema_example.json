{
  "schema_version": "1.0",
  "description": "US Banking comprehensive services schema - retail banking, loans, wire transfers, bill payments, and wealth management with realistic distributions",
  "tables": {
    "customers": {
      "description": "Bank customers - both retail and commercial",
      "columns": {
        "customer_id": {
          "type": "uuid",
          "primary_key": true
        },
        "customer_type": {
          "type": "varchar(20)",
          "nullable": false,
          "values": ["retail", "commercial", "corporate"],
          "distribution": {
            "retail": 0.80,
            "commercial": 0.18,
            "corporate": 0.02
          }
        },
        "first_name": {
          "type": "varchar(100)",
          "nullable": false,
          "generator": "realistic_first_name"
        },
        "last_name": {
          "type": "varchar(100)",
          "nullable": false,
          "generator": "realistic_last_name"
        },
        "email": {
          "type": "varchar(255)",
          "nullable": false,
          "unique": true,
          "generator": "email_from_name",
          "depends_on": ["first_name", "last_name"]
        },
        "phone": {
          "type": "varchar(20)",
          "nullable": true,
          "generator": "us_phone_number"
        },
        "address_line1": {
          "type": "varchar(255)",
          "nullable": false,
          "generator": "us_street_address"
        },
        "address_line2": {
          "type": "varchar(255)",
          "nullable": true,
          "null_rate": 0.70
        },
        "city": {
          "type": "varchar(100)",
          "nullable": false,
          "generator": "us_city_weighted"
        },
        "state": {
          "type": "varchar(2)",
          "nullable": false,
          "generator": "us_state_for_city",
          "depends_on": ["city"]
        },
        "postal_code": {
          "type": "varchar(10)",
          "nullable": false,
          "generator": "zip_for_city",
          "depends_on": ["city", "state"]
        },
        "date_of_birth": {
          "type": "date",
          "nullable": true,
          "generator": "date_of_birth",
          "min_age": 18,
          "max_age": 85
        },
        "national_id": {
          "type": "varchar(20)",
          "nullable": true,
          "generator": "ssn_last_4"
        },
        "customer_segment": {
          "type": "varchar(30)",
          "nullable": false,
          "values": ["standard", "priority", "wealth", "business", "corporate"],
          "distribution": {
            "standard": 0.65,
            "priority": 0.20,
            "wealth": 0.08,
            "business": 0.05,
            "corporate": 0.02
          }
        },
        "created_at": {
          "type": "timestamp",
          "nullable": false,
          "generator": "timestamp_in_period"
        }
      },
      "row_count": 2108
    },
    "accounts": {
      "description": "Bank accounts - checking, savings, and CDs",
      "columns": {
        "account_id": {
          "type": "uuid",
          "primary_key": true
        },
        "customer_id": {
          "type": "uuid",
          "nullable": false,
          "foreign_key": "customers.customer_id"
        },
        "account_number": {
          "type": "varchar(20)",
          "nullable": false,
          "unique": true,
          "generator": "account_number"
        },
        "account_type": {
          "type": "varchar(20)",
          "nullable": false,
          "values": ["checking", "savings", "certificate_deposit", "money_market"],
          "distribution": {
            "checking": 0.50,
            "savings": 0.35,
            "certificate_deposit": 0.10,
            "money_market": 0.05
          }
        },
        "account_status": {
          "type": "varchar(20)",
          "nullable": false,
          "values": ["active", "dormant", "closed"],
          "default": "active",
          "distribution": {
            "active": 0.85,
            "dormant": 0.10,
            "closed": 0.05
          }
        },
        "currency": {
          "type": "char(3)",
          "nullable": false,
          "default": "USD"
        },
        "balance": {
          "type": "numeric(15,2)",
          "nullable": false,
          "default": "0.00",
          "generator": "account_balance",
          "distribution": "lognormal",
          "mean": 8500,
          "std": 25000,
          "min": 0,
          "max": 500000
        },
        "interest_rate": {
          "type": "numeric(5,4)",
          "nullable": true,
          "generator": "account_interest_rate",
          "depends_on": ["account_type"]
        },
        "opened_at": {
          "type": "timestamp",
          "nullable": false,
          "generator": "timestamp_after_customer",
          "depends_on": ["customer_id"]
        },
        "closed_at": {
          "type": "timestamp",
          "nullable": true,
          "generator": "timestamp_after_opened",
          "depends_on": ["opened_at", "account_status"]
        }
      },
      "row_count": 3000
    },
    "loans": {
      "description": "Retail loans - personal, auto, mortgage, and business loans",
      "columns": {
        "loan_id": {
          "type": "uuid",
          "primary_key": true
        },
        "customer_id": {
          "type": "uuid",
          "nullable": false,
          "foreign_key": "customers.customer_id"
        },
        "loan_type": {
          "type": "varchar(30)",
          "nullable": false,
          "values": ["personal", "auto", "mortgage", "business", "education"],
          "distribution": {
            "personal": 0.20,
            "auto": 0.30,
            "mortgage": 0.30,
            "business": 0.10,
            "education": 0.10
          }
        },
        "principal_amount": {
          "type": "numeric(15,2)",
          "nullable": false,
          "generator": "loan_principal",
          "depends_on": ["loan_type"]
        },
        "outstanding_balance": {
          "type": "numeric(15,2)",
          "nullable": false,
          "generator": "loan_outstanding_balance",
          "depends_on": ["principal_amount", "origination_date", "loan_type"],
          "education_loan_avg": 81613,
          "education_loan_bias": "higher"
        },
        "interest_rate": {
          "type": "numeric(5,4)",
          "nullable": false,
          "generator": "loan_interest_rate",
          "depends_on": ["loan_type"]
        },
        "loan_term_months": {
          "type": "integer",
          "nullable": false,
          "generator": "loan_term",
          "depends_on": ["loan_type"]
        },
        "monthly_payment": {
          "type": "numeric(12,2)",
          "nullable": false,
          "generator": "loan_monthly_payment",
          "depends_on": ["principal_amount", "interest_rate", "loan_term_months"]
        },
        "loan_status": {
          "type": "varchar(20)",
          "nullable": false,
          "values": ["active", "paid_off", "defaulted", "restructured"],
          "distribution": {
            "active": 0.75,
            "paid_off": 0.20,
            "defaulted": 0.03,
            "restructured": 0.02
          }
        },
        "origination_date": {
          "type": "date",
          "nullable": false,
          "generator": "date_in_period"
        },
        "maturity_date": {
          "type": "date",
          "nullable": false,
          "generator": "date_after_origination",
          "depends_on": ["origination_date", "loan_term_months"]
        },
        "last_payment_date": {
          "type": "date",
          "nullable": true,
          "generator": "loan_last_payment_date",
          "depends_on": ["origination_date", "loan_status"]
        }
      },
      "row_count": 2500
    },
    "cards": {
      "description": "Debit and credit cards issued to customers",
      "columns": {
        "card_id": {
          "type": "uuid",
          "primary_key": true
        },
        "customer_id": {
          "type": "uuid",
          "nullable": false,
          "foreign_key": "customers.customer_id"
        },
        "account_id": {
          "type": "uuid",
          "nullable": true,
          "foreign_key": "accounts.account_id",
          "generator": "account_for_customer",
          "depends_on": ["customer_id"]
        },
        "card_number": {
          "type": "varchar(19)",
          "nullable": false,
          "unique": true,
          "generator": "card_number",
          "depends_on": ["card_network"]
        },
        "card_type": {
          "type": "varchar(20)",
          "nullable": false,
          "values": ["debit", "credit"],
          "distribution": {
            "debit": 0.55,
            "credit": 0.45
          }
        },
        "card_network": {
          "type": "varchar(20)",
          "nullable": false,
          "values": ["Visa", "Mastercard"],
          "distribution": {
            "Visa": 0.60,
            "Mastercard": 0.40
          }
        },
        "expiration_month": {
          "type": "smallint",
          "nullable": false,
          "generator": "random_month"
        },
        "expiration_year": {
          "type": "smallint",
          "nullable": false,
          "generator": "future_year",
          "depends_on": ["issued_at"]
        },
        "cvv": {
          "type": "char(3)",
          "nullable": false,
          "generator": "cvv"
        },
        "credit_limit": {
          "type": "numeric(10,2)",
          "nullable": true,
          "generator": "credit_limit",
          "depends_on": ["card_type"]
        },
        "status": {
          "type": "varchar(20)",
          "nullable": false,
          "values": ["active", "suspended", "closed"],
          "default": "active",
          "distribution": {
            "active": 0.88,
            "suspended": 0.05,
            "closed": 0.07
          }
        },
        "issued_at": {
          "type": "timestamp",
          "nullable": false,
          "generator": "timestamp_in_period"
        }
      },
      "row_count": 2300
    },
    "card_transactions": {
      "description": "Card payment transactions at POS and online",
      "columns": {
        "transaction_id": {
          "type": "uuid",
          "primary_key": true
        },
        "card_id": {
          "type": "uuid",
          "nullable": false,
          "foreign_key": "cards.card_id"
        },
        "merchant_name": {
          "type": "varchar(255)",
          "nullable": false,
          "generator": "merchant_name",
          "depends_on": ["merchant_category", "merchant_country"]
        },
        "merchant_category": {
          "type": "varchar(100)",
          "nullable": false,
          "generator": "merchant_category"
        },
        "merchant_city": {
          "type": "varchar(100)",
          "nullable": false,
          "generator": "merchant_city",
          "depends_on": ["merchant_country"]
        },
        "merchant_country": {
          "type": "char(2)",
          "nullable": false,
          "default": "US",
          "generator": "merchant_country",
          "distribution": {
            "US": 0.95,
            "international": 0.05
          }
        },
        "transaction_amount": {
          "type": "numeric(10,2)",
          "nullable": false,
          "generator": "transaction_amount",
          "depends_on": ["merchant_category"]
        },
        "transaction_currency": {
          "type": "char(3)",
          "nullable": false,
          "default": "USD",
          "generator": "currency_for_country",
          "depends_on": ["merchant_country"]
        },
        "billing_amount": {
          "type": "numeric(10,2)",
          "nullable": false,
          "generator": "billing_amount",
          "depends_on": ["transaction_amount", "transaction_currency"]
        },
        "pos_entry_mode": {
          "type": "varchar(20)",
          "nullable": false,
          "values": ["chip", "swipe", "contactless", "manual", "ecommerce"],
          "distribution": {
            "chip": 0.50,
            "contactless": 0.25,
            "swipe": 0.10,
            "ecommerce": 0.12,
            "manual": 0.03
          }
        },
        "auth_response": {
          "type": "varchar(20)",
          "nullable": false,
          "values": ["approved", "declined"],
          "distribution": {
            "approved": 0.88,
            "declined": 0.12
          }
        },
        "decline_reason": {
          "type": "varchar(100)",
          "nullable": true,
          "generator": "decline_reason",
          "depends_on": ["auth_response"]
        },
        "transaction_date": {
          "type": "timestamp",
          "nullable": false,
          "generator": "timestamp_in_period"
        }
      },
      "row_count": 85000
    },
    "wire_transfers": {
      "description": "Domestic and international wire transfers",
      "columns": {
        "transfer_id": {
          "type": "uuid",
          "primary_key": true
        },
        "from_account_id": {
          "type": "uuid",
          "nullable": false,
          "foreign_key": "accounts.account_id"
        },
        "transfer_type": {
          "type": "varchar(20)",
          "nullable": false,
          "values": ["domestic", "international"],
          "distribution": {
            "domestic": 0.70,
            "international": 0.30
          }
        },
        "beneficiary_name": {
          "type": "varchar(255)",
          "nullable": false,
          "generator": "beneficiary_name",
          "depends_on": ["beneficiary_country"]
        },
        "beneficiary_account": {
          "type": "varchar(50)",
          "nullable": false,
          "generator": "beneficiary_account"
        },
        "beneficiary_bank": {
          "type": "varchar(255)",
          "nullable": false,
          "generator": "bank_name",
          "depends_on": ["beneficiary_country"]
        },
        "beneficiary_country": {
          "type": "char(2)",
          "nullable": false,
          "generator": "wire_country",
          "depends_on": ["transfer_type"]
        },
        "transfer_amount": {
          "type": "numeric(15,2)",
          "nullable": false,
          "generator": "wire_transfer_amount",
          "distribution": "lognormal",
          "mean": 16913,
          "std": 28000,
          "min": 100,
          "max": 500000
        },
        "transfer_currency": {
          "type": "char(3)",
          "nullable": false,
          "generator": "currency_for_country",
          "depends_on": ["beneficiary_country"]
        },
        "exchange_rate": {
          "type": "numeric(10,6)",
          "nullable": true,
          "generator": "exchange_rate",
          "depends_on": ["transfer_currency"]
        },
        "transfer_fee": {
          "type": "numeric(8,2)",
          "nullable": false,
          "generator": "wire_transfer_fee",
          "depends_on": ["transfer_type", "transfer_amount"]
        },
        "swift_code": {
          "type": "varchar(11)",
          "nullable": true,
          "generator": "swift_code",
          "depends_on": ["transfer_type"]
        },
        "transfer_purpose": {
          "type": "varchar(100)",
          "nullable": true,
          "generator": "transfer_purpose"
        },
        "transfer_status": {
          "type": "varchar(20)",
          "nullable": false,
          "values": ["pending", "processing", "completed", "failed", "cancelled"],
          "distribution": {
            "pending": 0.05,
            "processing": 0.08,
            "completed": 0.82,
            "failed": 0.03,
            "cancelled": 0.02
          }
        },
        "initiated_at": {
          "type": "timestamp",
          "nullable": false,
          "generator": "timestamp_in_period"
        },
        "completed_at": {
          "type": "timestamp",
          "nullable": true,
          "generator": "timestamp_after_initiated",
          "depends_on": ["initiated_at", "transfer_status", "transfer_type"],
          "min_seconds": 1800,
          "max_seconds": 259200
        }
      },
      "row_count": 3200
    },
    "bill_payments": {
      "description": "Utility and service bill payments",
      "columns": {
        "payment_id": {
          "type": "uuid",
          "primary_key": true
        },
        "account_id": {
          "type": "uuid",
          "nullable": false,
          "foreign_key": "accounts.account_id"
        },
        "biller_name": {
          "type": "varchar(255)",
          "nullable": false,
          "generator": "biller_name",
          "depends_on": ["bill_type"]
        },
        "bill_type": {
          "type": "varchar(30)",
          "nullable": false,
          "values": ["electricity", "water", "telecom", "internet", "insurance", "education", "government"],
          "distribution": {
            "electricity": 0.20,
            "water": 0.15,
            "telecom": 0.20,
            "internet": 0.18,
            "insurance": 0.15,
            "education": 0.07,
            "government": 0.05
          }
        },
        "account_number": {
          "type": "varchar(50)",
          "nullable": false,
          "generator": "bill_account_number"
        },
        "payment_amount": {
          "type": "numeric(10,2)",
          "nullable": false,

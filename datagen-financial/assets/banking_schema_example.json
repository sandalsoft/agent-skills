        },
        "payment_currency": {
          "type": "char(3)",
          "nullable": false,
          "default": "USD"
        },
        "payment_method": {
          "type": "varchar(20)",
          "nullable": false,
          "values": ["online", "branch", "atm", "mobile_app"],
          "distribution": {
            "online": 0.45,
            "mobile_app": 0.40,
            "branch": 0.10,
            "atm": 0.05
          }
        },
        "payment_status": {
          "type": "varchar(20)",
          "nullable": false,
          "values": ["pending", "completed", "failed"],
          "distribution": {
            "pending": 0.08,
            "completed": 0.89,
            "failed": 0.03
          }
        },
        "scheduled_date": {
          "type": "date",
          "nullable": true,
          "generator": "bill_scheduled_date"
        },
        "payment_date": {
          "type": "timestamp",
          "nullable": false,
          "generator": "timestamp_near_scheduled",
          "depends_on": ["scheduled_date"]
        }
      },
      "row_count": 12500
    },
    "wealth_management_accounts": {
      "description": "Investment and wealth management accounts",
      "columns": {
        "portfolio_id": {
          "type": "uuid",
          "primary_key": true
        },
        "customer_id": {
          "type": "uuid",
          "nullable": false,
